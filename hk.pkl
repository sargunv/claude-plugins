amends "package://github.com/jdx/hk/releases/download/v1.41.0/hk@1.41.0#/Config.pkl"

import "package://github.com/jdx/hk/releases/download/v1.41.0/hk@1.41.0#/Builtins.pkl"

local allSteps = new Mapping<String, Step> {
  ["dprint"] = Builtins.dprint
  ["claudelint"] = new Step {
    check = "claudelint --strict"
    glob = List("plugins/**", ".claude-plugin/**")
  }
}

hooks {
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps {
      ...allSteps
    }
  }
  ["check"] {
    steps {
      ...allSteps
    }
  }
  ["fix"] {
    fix = true
    steps {
      ...allSteps
    }
  }
}
